# ==============================
# ChatFlow 360 SaaS - Backend Webhook
# ==============================
PORT=3000
NODE_ENV=production
PUBLIC_BASE_URL=https://TU-BACKEND.up.railway.app
CORS_ORIGIN=*

# Supabase - usar SERVICE_ROLE solo en backend, nunca en frontend
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
DEFAULT_EMPRESA_ID=

# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=chatflow360_verify_2026_seguro
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_REDIRECT_URI=https://TU-BACKEND.up.railway.app/meta/callback
META_ACCESS_TOKEN=EAAG...TU_TOKEN_PERMANENTE
META_API_VERSION=v23.0
PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID

# IA: gemini, openai, deepseek o mock
AI_PROVIDER=gemini
GEMINI_API_KEY=TU_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / DeepSeek compatible, usar solo si AI_PROVIDER=openai o deepseek
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Seguridad interna del API para el dashboard, puedes inventar una clave larga
DASHBOARD_API_KEY=chatflow360_dashboard_2026_cambiar


# V16.11 QR asistido / Evolution API
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://tu-evolution-api.up.railway.app
EVOLUTION_API_KEY=pon_aqui_la_apikey_de_evolution
EVOLUTION_DEFAULT_COUNTRY_CODE=591

# V16.28 Cola segura Redis + Worker
# Si REDIS_URL está vacío, el backend sigue procesando como antes sin cola.
REDIS_URL=
QUEUE_ENABLED=true
QUEUE_NAME=chatflow360_messages
QUEUE_CONCURRENCY=1
QUEUE_REMOVE_ON_COMPLETE=1000
QUEUE_REMOVE_ON_FAIL=5000
MESSAGE_RETRY_LIMIT=3
MESSAGE_RETRY_DELAY_MS=5000
